[user]
    email = dev@eacarsoy.com
    name = Emre Acarsoy
    signingkey = ~/.ssh/id_ed25519.pub

[core]
    # Use VS Code instead of vim
    editor = code --wait

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/allowed_signers

[commit]
    gpgSign = true

[tag]
    gpgSign = true

[init]
    defaultBranch = main

[fetch]
    # Prune deleted remote branches
    prune = true

[pull]
    # Explicitly rebase on pull
    rebase = true

[rebase]
    autoStash = true

[alias]
    st = status -s
    uncommit = reset --soft HEAD~1
    editcommit = commit --amend
    track = "!f() { git branch --set-upstream-to=origin/$1; }; f"
    gamend = "!f() { now=$(date -R); git add -A && git commit --amend --no-edit --date=\"$now\"; }; f"